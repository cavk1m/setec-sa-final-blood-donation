  "testing_tips": {
    "general": [
      "Always keep the JWT token in the Authorization header: Bearer <token>",
      "Tokens expire after 24 hours of inactivity",
      "Use the environment variables {{base_url}}, {{jwt_token}}, etc.",
      "OTP codes are valid for 10 minutes",
      "Max 5 OTP requests per email per hour"
    ],
    "user_testing": [
      "Test with different blood types",
      "Verify password requirements (min 8 chars, uppercase, digit, special char)",
      "Test profile picture upload (max 5MB)",
      "Test password change with old password",
      "Test account deactivation (irreversible)"
    ],
    "hospital_testing": [
      "Hospital must be verified by admin before full operations",
      "Test blood unit updates with realistic numbers",
      "Test coordinator updates for staff changes",
      "Admin operations require ADMIN or SUPER_ADMIN role"
    ],
    "admin_testing": [
      "Need ADMIN or SUPER_ADMIN role for admin endpoints",
      "Test role and permission management",
      "Verify hospital approval workflow",
      "Test hospital admin creation and management"
    ]
  }
