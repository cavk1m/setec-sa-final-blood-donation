  "workflows": {
    "user_registration_workflow": {
      "steps": [
        "1. POST /api/users/register with user data",
        "2. Check email for OTP code",
        "3. POST /api/users/verify-otp with email and OTP",
        "4. User is now registered and email verified",
        "5. POST /api/users/login to get JWT token"
      ]
    },
    "hospital_registration_workflow": {
      "steps": [
        "1. POST /api/hospitals/register with hospital data",
        "2. Save hospital ID from response",
        "3. Admin must verify hospital: PUT /api/admin/hospitals/{id}/verify",
        "4. Hospital can now perform operations"
      ]
    },
    "admin_user_creation_workflow": {
      "steps": [
        "1. Have ADMIN or SUPER_ADMIN JWT token",
        "2. GET /api/admin/hospitals to get hospital IDs",
        "3. POST /api/hospitals/{id}/admins to add new hospital admin",
        "4. New admin can login with provided credentials"
      ]
    },
    "permission_management_workflow": {
      "steps": [
        "1. Have SUPER_ADMIN JWT token",
        "2. GET /api/admin/permissions to list all permissions",
        "3. GET /api/admin/roles to list all roles",
        "4. POST /api/admin/roles/{roleId}/permissions/{permissionId} to add permission to role",
        "5. DELETE /api/admin/roles/{roleId}/permissions/{permissionId} to remove permission"
      ]
    }
  },
  "error_codes": {
    "400": "Bad Request - Invalid input or validation failed",
    "401": "Unauthorized - Missing or invalid JWT token",
    "403": "Forbidden - User doesn't have required permission/role",
    "404": "Not Found - Resource not found",
    "409": "Conflict - Email/Phone already registered",
    "422": "Unprocessable Entity - Validation error on entity",
    "429": "Too Many Requests - Rate limit exceeded (5 OTP requests/hour)",
    "500": "Internal Server Error - Server error"
  },
