        "poolSize": "HikariCP"
      },
      "jpa": {
        "hibernateDialect": "org.hibernate.dialect.PostgreSQLDialect",
        "ddlAuto": "update",
        "openInView": false
      }
    },
    "server": {
      "port": 8081,
      "servlet": {
        "contextPath": "/"
      }
    },
    "security": {
      "jwt": {
        "algorithm": "HS256",
        "validity": "24 hours"
      },
      "otp": {
        "length": 6,
        "validity": "10 minutes",
        "rateLimit": "5 per hour",
        "retryLimit": 3
      },
      "password": {
        "encryption": "BCrypt",
        "strength": 10,
        "requirements": {
          "minLength": 8,
          "uppercase": true,
          "lowercase": true,
          "digit": true,
          "specialChar": true
        }
      }
    }
  },
